<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin</title>
    <style>
      :root{
        --bg0:#070a11;
        --bg1:#0b1220;
        --card:rgba(17,24,39,.78);
        --stroke:rgba(148,163,184,.18);
        --text:#e5e7eb;
        --muted:#a3adc2;
        --brand1:#a78bfa;
        --brand2:#22d3ee;
        --ok:#22c55e;
        --danger:#ef4444;
        --shadow: 0 22px 70px rgba(0,0,0,.55);
      }
      *{ box-sizing:border-box; }
      body{
        font-family: Arial, Helvetica, sans-serif;
        margin:0;
        color:var(--text);
        background:
          radial-gradient(1000px 600px at 12% 0%, rgba(167,139,250,.22), transparent 55%),
          radial-gradient(900px 520px at 90% 10%, rgba(34,211,238,.14), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        min-height:100vh;
      }
      .top{
        position: sticky;
        top:0;
        z-index:10;
        display:flex;
        align-items:center;
        justify-content:space-between;
        padding: 14px 18px;
        border-bottom:1px solid var(--stroke);
        background: rgba(7,10,17,.72);
        backdrop-filter: blur(14px);
      }
      .brand{
        display:flex;
        gap:12px;
        align-items:center;
      }
      .logo{
        width:34px;height:34px;border-radius:12px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow: 0 10px 30px rgba(167,139,250,.18);
      }
      .brandTitle{ font-weight:900; letter-spacing:.2px; }
      .muted{ color:var(--muted); font-size: 13px; }
      .wrap{ max-width: 1100px; margin: 18px auto; padding: 0 16px 44px; }
      .layout{ display:block; }
      .card{
        padding: 18px;
        border:1px solid var(--stroke);
        background: var(--card);
        backdrop-filter: blur(14px);
        border-radius: 18px;
        box-shadow: var(--shadow);
      }
      .grid{ display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      @media (max-width: 760px){ .grid{ grid-template-columns: 1fr; } }
      label{ display:block; margin: 0 0 6px; color:#cbd5e1; font-size: 12px; }
      .field{
        padding:12px;
        border-radius:16px;
        border:1px solid var(--stroke);
        background: rgba(11,18,32,.72);
      }
      input, textarea{
        width:100%;
        padding:12px 12px;
        border-radius: 12px;
        border:1px solid rgba(148,163,184,.22);
        background: rgba(2,6,23,.55);
        color:var(--text);
        outline:none;
      }
      input:focus, textarea:focus{
        border-color: rgba(167,139,250,.55);
        box-shadow: 0 0 0 4px rgba(167,139,250,.12);
      }
      textarea{ min-height: 96px; resize: vertical; }
      .btn{
        padding: 10px 12px;
        border-radius: 14px;
        border:1px solid rgba(148,163,184,.22);
        background: rgba(2,6,23,.55);
        color:var(--text);
        cursor:pointer;
        font-weight:800;
        transition: transform .08s ease, filter .2s ease;
      }
      .btn:hover{ filter: brightness(1.05); }
      .btn:active{ transform: translateY(1px) scale(.99); }
      .btnPrimary{
        border:0;
        color:#06101a;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
      }
      .pill{
        display:inline-flex;
        gap:8px;
        align-items:center;
        font-size:12px;
        color:var(--muted);
        border:1px solid var(--stroke);
        padding:6px 10px;
        border-radius:999px;
      }
      .dot{
        width:8px;height:8px;border-radius:99px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
      }
      .msgOk{
        margin: 12px 0;
        padding: 10px 12px;
        background: rgba(34,197,94,.12);
        border:1px solid rgba(34,197,94,.35);
        border-radius:14px;
        color:#bbf7d0;
      }
      .msgErr{
        margin: 12px 0;
        padding: 10px 12px;
        background: rgba(239,68,68,.12);
        border:1px solid rgba(239,68,68,.35);
        border-radius:14px;
        color:#fecaca;
      }
      .sectionTitle{
        margin: 0 0 10px;
        font-size: 13px;
        letter-spacing:.12em;
        text-transform: uppercase;
        color:#dbeafe;
      }
      .actionsBar{
        display:flex;
        gap:10px;
        align-items:center;
      }
      .k{
        border:1px solid var(--stroke);
        background: rgba(2,6,23,.35);
        border-radius:16px;
        padding:14px 14px;
      }
      .k h3{ margin:0 0 8px; font-size:14px; color:#e2e8f0; }
      .k p{ margin:0; font-size:12px; color:var(--muted); line-height:1.6; }
      .mono{
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size:12px;
        color:#dbeafe;
      }
      a{ color:#bfe3ff; text-decoration:none; }
      a:hover{ text-decoration:underline; }
    </style>
  </head>
  <body>
    <div class="top">
      <div class="brand">
        <div class="logo" aria-hidden="true"></div>
        <div>
          <div class="brandTitle">Oasis CMS</div>
          <div class="muted">Trang quản trị nội dung website</div>
        </div>
      </div>
      <div class="actionsBar">
        <span class="pill"><span class="dot"></span> Live</span>
        <a class="btn" href="/" target="_blank" rel="noreferrer">Mở website</a>
        <a class="btn" href="/admin/rooms">Rooms</a>
        <form method="post" action="/admin/logout" style="margin:0">
          <button class="btn" type="submit">Đăng xuất</button>
        </form>
      </div>
    </div>

    <div class="wrap">
      <div class="layout">
        <div class="card">
          <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
            <div>
              <h2 class="sectionTitle">Nội dung chung</h2>
              <p class="muted" style="margin:0">
                Lưu xong thì refresh website để thấy thay đổi (cập nhật qua <span class="mono">/api/public/settings</span>).
              </p>
            </div>
          </div>

          <% if (saved) { %>
            <div class="msgOk">Đã lưu. Refresh trang website để thấy thay đổi.</div>
          <% } %>

          <% if (errors) { %>
            <div class="msgErr">Lỗi dữ liệu. Vui lòng kiểm tra lại các trường (đặc biệt là Email / URL social).</div>
          <% } %>

          <form method="post" action="/admin/settings">
            <div class="grid">
              <div class="field">
                <label>Site name</label>
                <input name="siteName" value="<%= settings.siteName %>" required />
              </div>
              <div class="field">
                <label>Email</label>
                <input name="emailAddress" type="email" value="<%= settings.emailAddress %>" required />
              </div>
              <div class="field">
                <label>Hotline label</label>
                <input name="hotlineLabel" value="<%= settings.hotlineLabel %>" required />
              </div>
              <div class="field">
                <label>Hotline number</label>
                <input name="hotlineNumber" value="<%= settings.hotlineNumber %>" required />
              </div>
            </div>

            <div style="margin-top:16px">
              <h2 class="sectionTitle">Hero / thông báo</h2>
              <div class="grid">
                <div class="field">
                  <label>Hero title</label>
                  <input name="heroTitle" value="<%= settings.heroTitle %>" required />
                </div>
                <div class="field">
                  <label>Hero note title</label>
                  <input name="heroNoteTitle" value="<%= settings.heroNoteTitle %>" required />
                </div>
              </div>
              <div class="field" style="margin-top:12px;">
                <label>Hero note body</label>
                <textarea name="heroNoteBody" required><%= settings.heroNoteBody %></textarea>
              </div>
            </div>

            <div style="margin-top:16px">
              <h2 class="sectionTitle">Social links</h2>
              <div class="grid">
                <div class="field">
                  <label>Facebook URL</label>
                  <input name="facebook" value="<%= settings.social.facebook || '' %>" />
                </div>
                <div class="field">
                  <label>Instagram URL</label>
                  <input name="instagram" value="<%= settings.social.instagram || '' %>" />
                </div>
                <div class="field">
                  <label>YouTube URL</label>
                  <input name="youtube" value="<%= settings.social.youtube || '' %>" />
                </div>
                <div class="field">
                  <label>Twitter URL</label>
                  <input name="twitter" value="<%= settings.social.twitter || '' %>" />
                </div>
                <div class="field">
                  <label>Pinterest URL</label>
                  <input name="pinterest" value="<%= settings.social.pinterest || '' %>" />
                </div>
                <div></div>
              </div>
            </div>

            <div style="margin-top:16px">
              <h2 class="sectionTitle">Footer</h2>
              <div class="field">
                <label>Copyright</label>
                <input name="copyrightText" value="<%= settings.copyrightText %>" required />
              </div>
            </div>

            <div style="display:flex; gap: 10px; margin-top: 14px; flex-wrap: wrap;">
              <button class="btn btnPrimary" type="submit">Lưu thay đổi</button>
              <a class="btn" href="/admin">Reset form</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>

