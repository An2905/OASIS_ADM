<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login</title>
    <style>
      body { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial; background:#0b0f17; color:#e5e7eb; margin:0; }
      .wrap { max-width: 420px; margin: 10vh auto; padding: 24px; background:#111827; border:1px solid #1f2937; border-radius: 14px; }
      label { display:block; margin: 12px 0 6px; color:#cbd5e1; font-size: 14px; }
      input { width:100%; padding:12px; border-radius:10px; border:1px solid #334155; background:#0b1220; color:#e5e7eb; }
      button { width:100%; margin-top:16px; padding:12px; border:0; border-radius:10px; background:#3b82f6; color:white; font-weight:600; cursor:pointer; }
      .err { margin-top: 12px; padding: 10px 12px; background:#3f1d1d; border:1px solid #7f1d1d; border-radius:10px; color:#fecaca; }
      .hint { margin-top: 14px; font-size: 12px; color:#94a3b8; }
      a { color:#93c5fd; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <h1 style="margin:0 0 6px; font-size:22px;">Đăng nhập quản trị</h1>
      <p style="margin:0 0 18px; color:#94a3b8;">Chỉnh nội dung hiển thị trên website.</p>
      <form method="post" action="/admin/login">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="username" required />
        <label for="password">Mật khẩu</label>
        <input id="password" name="password" type="password" autocomplete="current-password" required />
        <button type="submit">Đăng nhập</button>
      </form>
      <% if (error) { %>
        <div class="err"><%= error %></div>
      <% } %>
      <div class="hint">
        Tạo tài khoản admin bằng biến môi trường `ADMIN_EMAIL`, `ADMIN_PASSWORD` và chạy seed.
      </div>
    </div>
  </body>
</html>

