<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập quản trị</title>
    <style>
      :root{
        --bg0:#070a11;
        --bg1:#0b1220;
        --card:rgba(17,24,39,.78);
        --stroke:rgba(148,163,184,.18);
        --text:#e5e7eb;
        --muted:#a3adc2;
        --brand1:#a78bfa;
        --brand2:#22d3ee;
        --danger:#ef4444;
        --shadow: 0 20px 60px rgba(0,0,0,.55);
      }
      *{ box-sizing:border-box; }
      body{
        font-family: Arial, Helvetica, sans-serif;
        margin:0;
        color:var(--text);
        background:
          radial-gradient(1000px 600px at 15% 10%, rgba(167,139,250,.22), transparent 55%),
          radial-gradient(900px 520px at 85% 20%, rgba(34,211,238,.16), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        min-height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        padding:28px 16px;
      }
      .wrap{
        width:min(560px, 100%);
        display:block;
      }
      .panel{
        border:1px solid var(--stroke);
        background: var(--card);
        backdrop-filter: blur(14px);
        border-radius: 18px;
        box-shadow: var(--shadow);
        overflow:hidden;
      }
      .left{
        padding:26px 26px 18px;
        position:relative;
      }
      .badge{
        display:inline-flex;
        gap:8px;
        align-items:center;
        font-size:12px;
        color:var(--muted);
        border:1px solid var(--stroke);
        padding:6px 10px;
        border-radius:999px;
      }
      .dot{
        width:8px;height:8px;border-radius:99px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow: 0 0 0 4px rgba(167,139,250,.12);
      }
      h1{ margin:14px 0 8px; font-size:28px; letter-spacing:.2px; }
      .sub{ margin:0; color:var(--muted); line-height:1.55; }
      form{ margin-top:18px; display:grid; gap:12px; }
      label{ display:block; margin:0 0 6px; color:#cbd5e1; font-size: 13px; }
      .field{
        padding:12px;
        border-radius:14px;
        border:1px solid var(--stroke);
        background: rgba(11,18,32,.72);
      }
      input{
        width:100%;
        padding:12px 12px;
        border-radius: 12px;
        border:1px solid rgba(148,163,184,.22);
        background: rgba(2,6,23,.55);
        color:var(--text);
        outline:none;
      }
      input:focus{
        border-color: rgba(167,139,250,.55);
        box-shadow: 0 0 0 4px rgba(167,139,250,.12);
      }
      .actions{
        margin-top:6px;
        display:flex;
        gap:10px;
        align-items:center;
      }
      button{
        flex:1;
        padding:12px 14px;
        border:0;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        color:#06101a;
        font-weight:800;
        cursor:pointer;
        transition: transform .08s ease, filter .2s ease;
      }
      button:active{ transform: translateY(1px) scale(.99); }
      .err{
        margin-top: 12px;
        padding: 10px 12px;
        background: rgba(239,68,68,.12);
        border:1px solid rgba(239,68,68,.35);
        border-radius:14px;
        color:#fecaca;
      }
      .mono{
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size:12px;
        color:#dbeafe;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="panel left">
        <div class="badge"><span class="dot"></span> Oasis CMS</div>
        <h1>Đăng nhập quản trị</h1>
        <p class="sub">Chỉnh nội dung hiển thị trên website: hero, hotline, email, mạng xã hội, footer…</p>

      <form method="post" action="/loginDN">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="username" required />
          </div>
          <div class="field">
            <label for="password">Mật khẩu</label>
            <input id="password" name="password" type="password" autocomplete="current-password" required />
          </div>
          <div class="actions">
            <button type="submit">Đăng nhập</button>
          </div>
        </form>

        <% if (error) { %>
          <div class="err"><%= error %></div>
        <% } %>

      </div>
    </div>
  </body>
</html>

