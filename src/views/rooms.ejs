<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rooms</title>
    <style>
      :root{
        --bg0:#070a11;
        --bg1:#0b1220;
        --card:rgba(17,24,39,.78);
        --stroke:rgba(148,163,184,.18);
        --text:#e5e7eb;
        --muted:#a3adc2;
        --brand1:#a78bfa;
        --brand2:#22d3ee;
        --shadow: 0 22px 70px rgba(0,0,0,.55);
      }
      *{ box-sizing:border-box; }
      body{
        font-family: Arial, Helvetica, sans-serif;
        margin:0;
        color:var(--text);
        background:
          radial-gradient(1000px 600px at 12% 0%, rgba(167,139,250,.22), transparent 55%),
          radial-gradient(900px 520px at 90% 10%, rgba(34,211,238,.14), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        min-height:100vh;
      }
      .top{
        position: sticky;
        top:0;
        z-index:10;
        display:flex;
        align-items:center;
        justify-content:space-between;
        padding: 14px 18px;
        border-bottom:1px solid var(--stroke);
        background: rgba(7,10,17,.72);
        backdrop-filter: blur(14px);
      }
      .brand{ display:flex; gap:12px; align-items:center; }
      .logo{
        width:34px;height:34px;border-radius:12px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow: 0 10px 30px rgba(167,139,250,.18);
      }
      .brandTitle{ font-weight:900; letter-spacing:.2px; }
      .wrap{ max-width: 1100px; margin: 18px auto; padding: 0 16px 44px; }
      .card{
        padding: 18px;
        border:1px solid var(--stroke);
        background: var(--card);
        backdrop-filter: blur(14px);
        border-radius: 18px;
        box-shadow: var(--shadow);
      }
      .btn{
        display:inline-flex; align-items:center; gap:8px;
        padding:10px 12px; border-radius:14px;
        border:1px solid rgba(148,163,184,.22);
        background: rgba(2,6,23,.55);
        color:var(--text);
        text-decoration:none;
        font-weight:800;
        cursor:pointer;
      }
      .btnPrimary{ border:0; color:#06101a; background: linear-gradient(135deg, var(--brand1), var(--brand2)); }
      .muted{ color:var(--muted); font-size: 13px; }
      table{ width:100%; border-collapse: collapse; margin-top: 12px; }
      th, td{ text-align:left; padding:12px 10px; border-bottom:1px solid rgba(148,163,184,.14); font-size: 13px; }
      th{ color:#cbd5e1; font-weight:900; letter-spacing:.08em; text-transform:uppercase; font-size:12px; }
      .rowActions{ display:flex; gap:10px; align-items:center; }
      form{ margin:0; }
      .chip{
        display:inline-flex; align-items:center; gap:8px;
        border:1px solid var(--stroke);
        padding:6px 10px;
        border-radius: 999px;
        color: var(--muted);
        font-size: 12px;
      }
      .dot{ width:8px; height:8px; border-radius: 99px; background: linear-gradient(135deg, var(--brand1), var(--brand2)); }
    </style>
  </head>
  <body>
    <div class="top">
      <div class="brand">
        <div class="logo" aria-hidden="true"></div>
        <div>
          <div class="brandTitle">Room Categories</div>
          <div class="muted">Manage room tiers shown on the public site</div>
        </div>
      </div>
      <div style="display:flex; gap:10px;">
        <a class="btn" href="/admin">Back to CMS</a>
        <a class="btn btnPrimary" href="/admin/rooms/new">+ New room</a>
      </div>
    </div>
    <div class="wrap">
      <div class="card">
        <div class="chip"><span class="dot"></span> Exactly 6 concept images per room</div>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Slug</th>
              <th>Updated</th>
              <th style="width:220px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!rooms.length) { %>
              <tr><td colspan="4" class="muted">No rooms yet.</td></tr>
            <% } %>
            <% rooms.forEach((r) => { %>
              <tr>
                <td><%= r.name %></td>
                <td class="muted"><%= r.slug %></td>
                <td class="muted"><%= new Date(r.updatedAt).toLocaleString() %></td>
                <td>
                  <div class="rowActions">
                    <a class="btn" href="/admin/rooms/<%= r.id %>/edit">Edit</a>
                    <form method="post" action="/admin/rooms/<%= r.id %>/delete" onsubmit="return confirm('Delete this room?')">
                      <button class="btn" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>

