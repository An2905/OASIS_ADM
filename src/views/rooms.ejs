<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rooms</title>
    <style>
      body{ font-family: Arial, Helvetica, sans-serif; background:#0b1220; color:#e5e7eb; margin:0; }
      .top{ position:sticky; top:0; background:rgba(7,10,17,.85); backdrop-filter: blur(10px); border-bottom:1px solid rgba(148,163,184,.18); padding:14px 18px; display:flex; align-items:center; justify-content:space-between; }
      .wrap{ max-width: 1100px; margin:18px auto; padding: 0 16px 44px; }
      .card{ border:1px solid rgba(148,163,184,.18); background:rgba(17,24,39,.78); border-radius:16px; padding:16px; }
      .btn{ display:inline-flex; align-items:center; gap:8px; padding:10px 12px; border-radius:12px; border:1px solid rgba(148,163,184,.22); background:rgba(2,6,23,.55); color:#e5e7eb; text-decoration:none; font-weight:800; cursor:pointer; }
      .btnPrimary{ border:0; color:#06101a; background: linear-gradient(135deg, #a78bfa, #22d3ee); }
      table{ width:100%; border-collapse: collapse; margin-top: 10px; }
      th, td{ text-align:left; padding:10px; border-bottom:1px solid rgba(148,163,184,.14); font-size: 13px; }
      th{ color:#cbd5e1; font-weight:900; letter-spacing:.08em; text-transform:uppercase; font-size:12px; }
      .muted{ color:#a3adc2; }
      .rowActions{ display:flex; gap:8px; align-items:center; }
      form{ margin:0; }
    </style>
  </head>
  <body>
    <div class="top">
      <div style="font-weight:900">Room Categories</div>
      <div style="display:flex; gap:10px;">
        <a class="btn" href="/admin">Back to CMS</a>
        <a class="btn btnPrimary" href="/admin/rooms/new">+ New room</a>
      </div>
    </div>
    <div class="wrap">
      <div class="card">
        <div class="muted">Concept images are required: exactly 6 per room category.</div>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Slug</th>
              <th>Updated</th>
              <th style="width:220px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!rooms.length) { %>
              <tr><td colspan="4" class="muted">No rooms yet.</td></tr>
            <% } %>
            <% rooms.forEach((r) => { %>
              <tr>
                <td><%= r.name %></td>
                <td class="muted"><%= r.slug %></td>
                <td class="muted"><%= new Date(r.updatedAt).toLocaleString() %></td>
                <td>
                  <div class="rowActions">
                    <a class="btn" href="/admin/rooms/<%= r.id %>/edit">Edit</a>
                    <form method="post" action="/admin/rooms/<%= r.id %>/delete" onsubmit="return confirm('Delete this room?')">
                      <button class="btn" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>

