<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= mode === 'create' ? 'New room' : 'Edit room' %></title>
    <style>
      :root{
        --bg0:#070a11;
        --bg1:#0b1220;
        --card:rgba(17,24,39,.78);
        --stroke:rgba(148,163,184,.18);
        --text:#e5e7eb;
        --muted:#a3adc2;
        --brand1:#a78bfa;
        --brand2:#22d3ee;
        --danger:#ef4444;
        --shadow: 0 22px 70px rgba(0,0,0,.55);
      }
      *{ box-sizing:border-box; }
      body{
        font-family: Arial, Helvetica, sans-serif;
        margin:0;
        color:var(--text);
        background:
          radial-gradient(1000px 600px at 12% 0%, rgba(167,139,250,.22), transparent 55%),
          radial-gradient(900px 520px at 90% 10%, rgba(34,211,238,.14), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        min-height:100vh;
      }
      .top{
        position: sticky;
        top:0;
        z-index:10;
        display:flex;
        align-items:center;
        justify-content:space-between;
        padding: 14px 18px;
        border-bottom:1px solid var(--stroke);
        background: rgba(7,10,17,.72);
        backdrop-filter: blur(14px);
      }
      .brand{ display:flex; gap:12px; align-items:center; }
      .logo{
        width:34px;height:34px;border-radius:12px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow: 0 10px 30px rgba(167,139,250,.18);
      }
      .brandTitle{ font-weight:900; letter-spacing:.2px; }
      .muted{ color:var(--muted); font-size: 13px; }
      .wrap{ max-width: 1100px; margin:18px auto; padding: 0 16px 44px; }
      .card{
        padding: 18px;
        border:1px solid var(--stroke);
        background: var(--card);
        backdrop-filter: blur(14px);
        border-radius: 18px;
        box-shadow: var(--shadow);
      }
      .grid{ display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      @media (max-width: 860px){ .grid{ grid-template-columns: 1fr; } }
      label{ display:block; margin:0 0 6px; color:#cbd5e1; font-size: 12px; }
      input, textarea{
        width:100%;
        padding:12px;
        border-radius:12px;
        border:1px solid rgba(148,163,184,.22);
        background:rgba(2,6,23,.55);
        color:var(--text);
        outline:none;
      }
      input:focus, textarea:focus{
        border-color: rgba(167,139,250,.55);
        box-shadow: 0 0 0 4px rgba(167,139,250,.12);
      }
      textarea{ min-height: 120px; resize: vertical; }
      .btn{
        display:inline-flex; align-items:center; gap:8px;
        padding:10px 12px; border-radius:14px;
        border:1px solid rgba(148,163,184,.22);
        background:rgba(2,6,23,.55);
        color:var(--text);
        text-decoration:none;
        font-weight:800;
        cursor:pointer;
      }
      .btnPrimary{ border:0; color:#06101a; background: linear-gradient(135deg, var(--brand1), var(--brand2)); }
      .err{ margin: 12px 0; padding: 10px 12px; background: rgba(239,68,68,.12); border:1px solid rgba(239,68,68,.35); border-radius:12px; color:#fecaca; }
      .sectionTitle{ margin: 16px 0 10px; font-size: 12px; letter-spacing:.12em; text-transform: uppercase; color:#dbeafe; }
      .hint{ margin-top: 10px; padding: 10px 12px; border-radius: 12px; border:1px solid var(--stroke); background: rgba(2,6,23,.35); color: var(--muted); font-size: 13px; }
      .drop{
        margin-top: 8px;
        border: 1px dashed rgba(148,163,184,.35);
        background: rgba(2,6,23,.35);
        border-radius: 14px;
        padding: 12px;
      }
      .drop.drag{ border-color: rgba(167,139,250,.7); box-shadow: 0 0 0 4px rgba(167,139,250,.12); }
      .dropTop{ display:flex; align-items:center; justify-content:space-between; gap:10px; }
      .dropHint{ color: var(--muted); font-size: 12px; line-height: 1.5; }
      .thumb{ margin-top: 10px; width: 100%; aspect-ratio: 16 / 10; border-radius: 12px; overflow:hidden; border: 1px solid rgba(148,163,184,.18); background: rgba(0,0,0,.2); display:flex; align-items:center; justify-content:center; }
      .thumb img{ width: 100%; height: 100%; object-fit: cover; display:block; }
    </style>
  </head>
  <body>
    <div class="top">
      <div class="brand">
        <div class="logo" aria-hidden="true"></div>
        <div>
          <div class="brandTitle"><%= mode === 'create' ? 'New room category' : 'Edit room category' %></div>
          <div class="muted">Fields here are editable; amenities blocks stay fixed in the theme.</div>
        </div>
      </div>
      <div style="display:flex; gap:10px;">
        <a class="btn" href="/admin/rooms">Back</a>
        <a class="btn" href="/admin">CMS</a>
      </div>
    </div>

    <div class="wrap">
      <div class="card">
        <div class="hint">
          You can edit: name, size, bed, bathroom, description, included, and concept images (exactly 6). Amenities sections are fixed in the public layout.
        </div>

        <% if (errors && (errors.formErrors?.length || Object.keys(errors.fieldErrors || {}).length)) { %>
          <div class="err">
            <div><strong>Fix the following:</strong></div>
            <% (errors.formErrors || []).forEach((m) => { %>
              <div>- <%= m %></div>
            <% }) %>
            <% Object.entries(errors.fieldErrors || {}).forEach(([k, arr]) => { %>
              <div>- <%= k %>: <%= (arr || []).join(', ') %></div>
            <% }) %>
          </div>
        <% } %>

        <form method="post" action="<%= mode === 'create' ? '/admin/rooms' : ('/admin/rooms/' + room.id) %>">
          <div class="grid" style="margin-top:12px;">
            <div>
              <label>Slug (kebab-case)</label>
              <input name="slug" value="<%= room?.slug || '' %>" placeholder="deluxe" required />
            </div>
            <div>
              <label>Name</label>
              <input name="name" value="<%= room?.name || '' %>" placeholder="Deluxe" required />
            </div>
            <div>
              <label>Size</label>
              <input name="size" value="<%= room?.size || '' %>" placeholder="45 m²" />
            </div>
            <div>
              <label>Bed</label>
              <input name="bed" value="<%= room?.bed || '' %>" placeholder="1 King bed" />
            </div>
            <div>
              <label>Bathroom</label>
              <input name="bathroom" value="<%= room?.bathroom || '' %>" placeholder="1 bathroom with rain shower" />
            </div>
            <div></div>
          </div>

          <div class="sectionTitle">Description</div>
          <textarea name="description" required><%= room?.description || '' %></textarea>

          <div class="sectionTitle">Included (one per line)</div>
          <textarea name="included" required placeholder="Private balcony&#10;140x200 cm Elite bed&#10;..."><%= room?.included || '' %></textarea>

          <div class="sectionTitle">Concept images (exactly 6)</div>
          <% const imgs = room?.images || []; %>
          <div class="grid">
            <% for (let i = 0; i < 6; i++) { %>
              <div>
                <label>Image <%= i+1 %> URL</label>
                <input class="js-img-url" data-index="<%= i %>" name="image<%= i+1 %>Url" value="<%= imgs[i]?.url || '' %>" placeholder="/media/... or https://..." required />
                <label style="margin-top:8px;">Image <%= i+1 %> alt (optional)</label>
                <input name="image<%= i+1 %>Alt" value="<%= imgs[i]?.alt || '' %>" placeholder="Deluxe room concept" />

                <div class="drop js-drop" data-index="<%= i %>">
                  <div class="dropTop">
                    <div class="dropHint">
                      Drag & drop an image here, or pick a file. We will auto-scale to a standard size.
                    </div>
                    <div style="display:flex; gap:8px; align-items:center;">
                      <input class="js-file" data-index="<%= i %>" type="file" accept="image/*" style="max-width: 210px;" />
                      <button class="btn" type="button" onclick="window.__roomUploadClear(<%= i %>)">Clear</button>
                    </div>
                  </div>
                  <div class="thumb">
                    <% if (imgs[i]?.url) { %>
                      <img class="js-thumb" data-index="<%= i %>" src="<%= imgs[i].url %>" alt="" />
                    <% } else { %>
                      <img class="js-thumb" data-index="<%= i %>" src="" alt="" style="display:none;" />
                      <span class="muted">No image</span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% } %>
          </div>

          <div style="display:flex; gap:10px; margin-top:14px; flex-wrap:wrap;">
            <button class="btn btnPrimary" type="submit"><%= mode === 'create' ? 'Create room' : 'Save changes' %></button>
            <a class="btn" href="/admin/rooms">Cancel</a>
          </div>
        </form>
      </div>
    </div>

    <script>
      async function scaleImageToJpeg(file, maxW, maxH, quality) {
        const bmp = await createImageBitmap(file);
        const ratio = Math.min(maxW / bmp.width, maxH / bmp.height, 1);
        const w = Math.round(bmp.width * ratio);
        const h = Math.round(bmp.height * ratio);
        const canvas = document.createElement("canvas");
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(bmp, 0, 0, w, h);
        const blob = await new Promise((resolve) => canvas.toBlob(resolve, "image/jpeg", quality));
        return blob;
      }

      async function uploadBlob(blob) {
        const fd = new FormData();
        fd.append("file", blob, "concept.jpg");
        const res = await fetch("/admin/media/upload", { method: "POST", body: fd, credentials: "same-origin" });
        if (!res.ok) throw new Error("Upload failed");
        return await res.json();
      }

      function setThumb(i, url) {
        const img = document.querySelector('.js-thumb[data-index="' + i + '"]');
        if (!img) return;
        if (!url) {
          img.removeAttribute("src");
          img.style.display = "none";
          return;
        }
        img.src = url;
        img.style.display = "block";
      }

      function setUrl(i, url) {
        const input = document.querySelector('.js-img-url[data-index="' + i + '"]');
        if (input) input.value = url || "";
      }

      window.__roomUploadClear = function (i) {
        setUrl(i, "");
        setThumb(i, "");
        const file = document.querySelector('.js-file[data-index="' + i + '"]');
        if (file) file.value = "";
      };

      async function handleFile(i, file) {
        if (!file) return;
        const drop = document.querySelector('.js-drop[data-index="' + i + '"]');
        try {
          if (drop) drop.classList.add("drag");
          const blob = await scaleImageToJpeg(file, 1600, 1200, 0.82);
          const { url } = await uploadBlob(blob);
          setUrl(i, url);
          setThumb(i, url);
        } finally {
          if (drop) drop.classList.remove("drag");
        }
      }

      document.querySelectorAll(".js-file").forEach((inp) => {
        inp.addEventListener("change", (e) => {
          const i = Number(inp.dataset.index || "0");
          const f = inp.files && inp.files[0];
          handleFile(i, f);
        });
      });

      document.querySelectorAll(".js-drop").forEach((box) => {
        box.addEventListener("dragover", (e) => {
          e.preventDefault();
          box.classList.add("drag");
        });
        box.addEventListener("dragleave", () => box.classList.remove("drag"));
        box.addEventListener("drop", (e) => {
          e.preventDefault();
          box.classList.remove("drag");
          const i = Number(box.dataset.index || "0");
          const f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
          handleFile(i, f);
        });
      });

      // Keep preview in sync if user pastes a URL manually
      document.querySelectorAll(".js-img-url").forEach((inp) => {
        inp.addEventListener("input", () => {
          const i = Number(inp.dataset.index || "0");
          setThumb(i, inp.value);
        });
      });
    </script>
  </body>
</html>

