<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= mode === 'create' ? 'New room' : 'Edit room' %></title>
    <style>
      :root{
        --bg0:#070a11;
        --bg1:#0b1220;
        --card:rgba(17,24,39,.78);
        --stroke:rgba(148,163,184,.18);
        --text:#e5e7eb;
        --muted:#a3adc2;
        --brand1:#a78bfa;
        --brand2:#22d3ee;
        --danger:#ef4444;
        --shadow: 0 22px 70px rgba(0,0,0,.55);
      }
      *{ box-sizing:border-box; }
      body{
        font-family: Arial, Helvetica, sans-serif;
        margin:0;
        color:var(--text);
        background:
          radial-gradient(1000px 600px at 12% 0%, rgba(167,139,250,.22), transparent 55%),
          radial-gradient(900px 520px at 90% 10%, rgba(34,211,238,.14), transparent 60%),
          linear-gradient(180deg, var(--bg0), var(--bg1));
        min-height:100vh;
      }
      .top{
        position: sticky;
        top:0;
        z-index:10;
        display:flex;
        align-items:center;
        justify-content:space-between;
        padding: 14px 18px;
        border-bottom:1px solid var(--stroke);
        background: rgba(7,10,17,.72);
        backdrop-filter: blur(14px);
      }
      .brand{ display:flex; gap:12px; align-items:center; }
      .logo{
        width:34px;height:34px;border-radius:12px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow: 0 10px 30px rgba(167,139,250,.18);
      }
      .brandTitle{ font-weight:900; letter-spacing:.2px; }
      .muted{ color:var(--muted); font-size: 13px; }
      .wrap{ max-width: 1100px; margin:18px auto; padding: 0 16px 44px; }
      .card{
        padding: 18px;
        border:1px solid var(--stroke);
        background: var(--card);
        backdrop-filter: blur(14px);
        border-radius: 18px;
        box-shadow: var(--shadow);
      }
      .grid{ display:grid; grid-template-columns: 1fr 1fr; gap: 12px; }
      @media (max-width: 860px){ .grid{ grid-template-columns: 1fr; } }
      label{ display:block; margin:0 0 6px; color:#cbd5e1; font-size: 12px; }
      input, textarea{
        width:100%;
        padding:12px;
        border-radius:12px;
        border:1px solid rgba(148,163,184,.22);
        background:rgba(2,6,23,.55);
        color:var(--text);
        outline:none;
      }
      input:focus, textarea:focus{
        border-color: rgba(167,139,250,.55);
        box-shadow: 0 0 0 4px rgba(167,139,250,.12);
      }
      textarea{ min-height: 120px; resize: vertical; }
      .btn{
        display:inline-flex; align-items:center; gap:8px;
        padding:10px 12px; border-radius:14px;
        border:1px solid rgba(148,163,184,.22);
        background:rgba(2,6,23,.55);
        color:var(--text);
        text-decoration:none;
        font-weight:800;
        cursor:pointer;
      }
      .btnPrimary{ border:0; color:#06101a; background: linear-gradient(135deg, var(--brand1), var(--brand2)); }
      .err{ margin: 12px 0; padding: 10px 12px; background: rgba(239,68,68,.12); border:1px solid rgba(239,68,68,.35); border-radius:12px; color:#fecaca; }
      .sectionTitle{ margin: 16px 0 10px; font-size: 12px; letter-spacing:.12em; text-transform: uppercase; color:#dbeafe; }
      .hint{ margin-top: 10px; padding: 10px 12px; border-radius: 12px; border:1px solid var(--stroke); background: rgba(2,6,23,.35); color: var(--muted); font-size: 13px; }
    </style>
  </head>
  <body>
    <div class="top">
      <div class="brand">
        <div class="logo" aria-hidden="true"></div>
        <div>
          <div class="brandTitle"><%= mode === 'create' ? 'New room category' : 'Edit room category' %></div>
          <div class="muted">Fields here are editable; amenities blocks stay fixed in the theme.</div>
        </div>
      </div>
      <div style="display:flex; gap:10px;">
        <a class="btn" href="/admin/rooms">Back</a>
        <a class="btn" href="/admin">CMS</a>
      </div>
    </div>

    <div class="wrap">
      <div class="card">
        <div class="hint">
          You can edit: name, size, bed, bathroom, description, included, and concept images (exactly 6). Amenities sections are fixed in the public layout.
        </div>

        <% if (errors && (errors.formErrors?.length || Object.keys(errors.fieldErrors || {}).length)) { %>
          <div class="err">
            <div><strong>Fix the following:</strong></div>
            <% (errors.formErrors || []).forEach((m) => { %>
              <div>- <%= m %></div>
            <% }) %>
            <% Object.entries(errors.fieldErrors || {}).forEach(([k, arr]) => { %>
              <div>- <%= k %>: <%= (arr || []).join(', ') %></div>
            <% }) %>
          </div>
        <% } %>

        <form method="post" action="<%= mode === 'create' ? '/admin/rooms' : ('/admin/rooms/' + room.id) %>">
          <div class="grid" style="margin-top:12px;">
            <div>
              <label>Slug (kebab-case)</label>
              <input name="slug" value="<%= room?.slug || '' %>" placeholder="deluxe" required />
            </div>
            <div>
              <label>Name</label>
              <input name="name" value="<%= room?.name || '' %>" placeholder="Deluxe" required />
            </div>
            <div>
              <label>Size</label>
              <input name="size" value="<%= room?.size || '' %>" placeholder="45 m²" />
            </div>
            <div>
              <label>Bed</label>
              <input name="bed" value="<%= room?.bed || '' %>" placeholder="1 King bed" />
            </div>
            <div>
              <label>Bathroom</label>
              <input name="bathroom" value="<%= room?.bathroom || '' %>" placeholder="1 bathroom with rain shower" />
            </div>
            <div></div>
          </div>

          <div class="sectionTitle">Description</div>
          <textarea name="description" required><%= room?.description || '' %></textarea>

          <div class="sectionTitle">Included (one per line)</div>
          <textarea name="included" required placeholder="Private balcony&#10;140x200 cm Elite bed&#10;..."><%= room?.included || '' %></textarea>

          <div class="sectionTitle">Concept images (exactly 6)</div>
          <% const imgs = room?.images || []; %>
          <div class="grid">
            <% for (let i = 0; i < 6; i++) { %>
              <div>
                <label>Image <%= i+1 %> URL</label>
                <input name="image<%= i+1 %>Url" value="<%= imgs[i]?.url || '' %>" placeholder="/assets/uploads/...jpg or https://..." required />
                <label style="margin-top:8px;">Image <%= i+1 %> alt (optional)</label>
                <input name="image<%= i+1 %>Alt" value="<%= imgs[i]?.alt || '' %>" placeholder="Deluxe room concept" />
              </div>
            <% } %>
          </div>

          <div style="display:flex; gap:10px; margin-top:14px; flex-wrap:wrap;">
            <button class="btn btnPrimary" type="submit"><%= mode === 'create' ? 'Create room' : 'Save changes' %></button>
            <a class="btn" href="/admin/rooms">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>

